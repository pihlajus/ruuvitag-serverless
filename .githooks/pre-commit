#!/bin/sh
# Pre-commit hook: run gitleaks against staged changes.
# Aborts the commit if any secrets are detected.

if ! command -v gitleaks >/dev/null 2>&1; then
  echo "warn: gitleaks not installed — skipping secret scan"
  echo "      install with: brew install gitleaks"
  exit 0
fi

gitleaks protect --staged --redact --verbose
status=$?

if [ $status -ne 0 ]; then
  echo
  echo "ERROR: gitleaks detected secrets in staged changes."
  echo "       Review the output above and remove secrets before committing."
  echo "       To bypass (NOT RECOMMENDED): git commit --no-verify"
  exit 1
fi
